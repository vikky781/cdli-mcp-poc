# CDLI MCP Server Configuration
# Copy to .env and fill in values

# Base URL for CDLI API (default shown)
CDLI_BASE_URL=https://cdli.mpiwg-berlin.mpg.de/api/v1

# API key for authenticated CDLI endpoints (leave empty for public access)
CDLI_API_KEY=

# Request timeout in seconds
CDLI_TIMEOUT=15.0

# Maximum number of artifacts in a batch request
CDLI_MAX_BATCH=20
